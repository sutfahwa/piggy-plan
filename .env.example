# Firebase web config — copy to ".env" and fill with your project's values.
# Firebase console → Project settings → General → "Your apps" → Web app → SDK config.
# These are public client keys (safe to expose); access is controlled by Firestore
# security rules + Firebase Auth, not by hiding these.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
